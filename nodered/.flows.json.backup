    {
        "id": "0333b86f03308a60",
        "type": "function",
        "z": "0329be821138bde4",
        "name": "Procesar UI",
        "func": "let d = msg.payload;\n\nlet alerta = \"NORMAL\";\n\nif (d.soil < 30 && d.temp > 30 && d.lux > 70) {\n    alerta = \"ALERTA CRÍTICA: riesgo de estrés hídrico\";\n} else if (d.soil < 30) {\n    alerta = \"ALERTA: humedad del suelo baja\";\n} else if (d.temp > 32) {\n    alerta = \"ALERTA: temperatura elevada\";\n} else if (d.lux > 85) {\n    alerta = \"Aviso: radiación solar muy alta\";\n} else if (d.hum < 30) {\n    alerta = \"ALERTA: humedad ambiente baja\";\n}\n\nreturn [\n    { payload: d.temp },\n    { payload: d.hum },\n    { payload: d.soil },\n    { payload: d.lux },\n    { payload: alerta },\n    { payload: d.parcela }\n];",
        "outputs": 6,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 370,
        "y": 120,
        "wires": [
            [
                "654d1ec936aceaaf"
            ],
