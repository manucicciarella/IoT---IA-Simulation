        "includeThoughts": false,
        "systemInstruction": "",
        "systemInstructionType": "str",
        "outputProperty": "payload",
        "passthroughProperties": false,
        "responseFormat": "text",
        "schemaPropertiesData": "[]",
        "enumValues": "",
