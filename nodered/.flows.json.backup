    {
        "id": "0866c3493ef2709a",
        "type": "function",
        "z": "5ca8cb27f5ecfc74",
        "name": "Preparar contexto Agente LLM",
        "func": "let prediccion = msg.payload;\nlet d = msg.sensores || {};\nlet ctx = msg.contexto || {};\nlet ahora = new Date();\n\nmsg.payload = {\n    parcela: d.parcela || \"Parcela no especificada\",\n    datetime: ahora.toLocaleString(\"es-AR\"),\n    temp: d.temp ?? \"sin dato\",\n    hum_amb: d.hum ?? \"sin dato\",\n    hum_suelo: d.suelo ?? \"sin dato\",\n    radiacion: d.rad ?? \"sin dato\",\n    viento: ctx.viento ?? \"sin dato\",\n    bateria_dron: ctx.bateria_dron ?? ctx.bateria ?? \"sin dato\",\n    nivel_tanque: ctx.nivel_tanque ?? \"sin dato\",\n    ultimo_riego_horas: ctx.ultimo_riego_horas ?? \"sin dato\",\n    ultima_fumigacion_dias: ctx.ultima_fumigacion_dias ?? \"sin dato\",\n    tipo_cultivo: ctx.tipo_cultivo ?? \"sin dato\",\n    etapa_cultivo: ctx.etapa_cultivo ?? \"sin dato\",\n    prediccion_nn: prediccion\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 790,
        "y": 620,
        "wires": [
            [
                "71b47693f5da35fc",
                "793fdcd818d2dd06"
            ]
        ]
    },
