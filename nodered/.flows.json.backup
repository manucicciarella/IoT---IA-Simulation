            ]
        ]
    },
    {
        "id": "fn_parse_aa001",
        "type": "function",
        "z": "0329be821138bde4",
        "name": "Parsear dataset",
        "func": "try {\n    msg.payload = JSON.parse(msg.payload.toString());\n    node.status({fill:\"green\",shape:\"dot\",text:msg.payload.length+\" samples OK\"});\n    return msg;\n} catch(e) {\n    node.error(\"Dataset parse failed: \"+e.message, msg);\n    node.status({fill:\"red\",shape:\"ring\",text:\"parse error: \"+e.message});\n    return null;\n}",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 610,
        "y": 480,
        "wires": [
            [
                "ccab8bc38c90af33",
                "91960ea531d8197f"
            ]
        ]
    },
    {
        "id": "fn_norm_aa001",
        "type": "function",
        "z": "0329be821138bde4",
        "name": "Normalizar entrada",
        "func": "let d = msg.payload;\nmsg.payload = {\n    temp: parseFloat((d.temp / 50).toFixed(4)),\n    hum_amb: parseFloat((d.hum / 100).toFixed(4)),\n    hum_suelo: parseFloat((d.soil / 100).toFixed(4)),\n    radiacion: parseFloat((d.lux / 100).toFixed(4)),\n    viento: 0.2\n};\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 570,
        "y": 320,
        "wires": [
            [
                "ccab8bc38c90af33"
            ]
        ]
    },
    {
        "id": "fn_decode_aa001",
        "type": "function",
        "z": "0329be821138bde4",
        "name": "Decodificar salida NN",
        "func": "const ACCIONES = {\"0\":\"Normal\",\"1\":\"Regar\",\"2\":\"Fumigar\",\"3\":\"Alerta critica\",\"4\":\"Inspeccionar\"};\nconst COMANDOS = {\"0\":\"SISTEMA OK\",\"1\":\"Regar\",\"2\":\"Fumigar\",\"3\":\"ALERTA\",\"4\":\"Inspeccionar\"};\nlet salida = msg.payload;\nif (!salida || typeof salida[\"0\"] === \"undefined\") return null;\nlet maxKey = Object.keys(salida).reduce((a, b) => salida[a] > salida[b] ? a : b);\nmsg.accion = ACCIONES[maxKey];\nmsg.topic = \"cursoiot/Agus/comando\";\nmsg.payload = COMANDOS[maxKey];\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1080,
        "y": 320,
        "wires": [
            [
                "9fb72521d62fb3fc",
                "21077e1d488a4997",
                "fn_accion_ui_aa001"
            ]
        ]
    },
