    {
        "id": "file_in_aa001",
        "type": "file in",
        "z": "0329be821138bde4",
        "name": "Leer dataset",
        "filename": "/data/dataset_agro_nodered_sin_bateria.json",
        "filenameType": "str",
        "format": "utf8",
        "chunk": false,
        "sendError": false,
        "encoding": "none",
        "allProps": false,
        "x": 390,
