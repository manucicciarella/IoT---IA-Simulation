    {
        "id": "03defb7a379b37ac",
        "type": "function",
        "z": "5ca8cb27f5ecfc74",
        "name": "Reporte normal local",
        "func": "let s = msg.sensores || {};\nlet ctx = msg.contexto || {};\nlet pred = \"\";\n\nif (typeof msg.payload === \"string\") {\n    pred = msg.payload;\n} else if (msg.payload && msg.payload.prediccion_nn) {\n    pred = msg.payload.prediccion_nn;\n}\n\nmsg.payload = `ESTADO: MONITOREAR\nDIAGNÓSTICO: ${s.parcela || \"La parcela\"} se mantiene estable: temperatura ${s.temp} °C, suelo ${s.suelo}% y viento ${ctx.viento} km/h.\nMISIÓN: No iniciar vuelo del dron. Continuar monitoreo automático.`;\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1480,
        "y": 740,
        "wires": [
            [
                "1b1e78ef2f3ee09e",
                "bd2f53094b86b7ac"
            ]
        ]
    },
    {
        "id": "65b9f960bdd36c38",
        "type": "function",
        "z": "5ca8cb27f5ecfc74",
        "name": "Limpiar respuesta LLM",
        "func": "let texto = String(msg.payload || \"\").toUpperCase();\n\nlet comando = \"MONITOREAR\";\n\nif (texto.includes(\"ALERTA\") && (texto.includes(\"CR\\u00CDTICA\") || texto.includes(\"CRITICA\"))) {\n    comando = \"ALERTA CR\\u00CDTICA\";\n} else if (texto.includes(\"POSTERGAR\")) {\n    comando = \"POSTERGAR\";\n} else if (texto.includes(\"INSPECCIONAR\")) {\n    comando = \"INSPECCIONAR\";\n} else if (texto.includes(\"FUMIGAR\")) {\n    comando = \"FUMIGAR\";\n} else if (texto.includes(\"REGAR\")) {\n    comando = \"REGAR\";\n} else if (texto.includes(\"NORMAL\") || texto.includes(\"MONITOREAR\")) {\n    comando = \"MONITOREAR\";\n}\n\nmsg.topic = \"cursoiot/grupo3/comandos\";\nmsg.payload = comando;\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1660,
        "y": 600,
        "wires": [
            [
                "1b1e78ef2f3ee09e",
                "bd2f53094b86b7ac",
                "97f23fcfd099bf31"
            ]
        ]
    },
    {
        "id": "95f016e73c9247c8",
        "type": "function",
        "z": "5ca8cb27f5ecfc74",
        "name": "Error Agente LLM",
        "func": "msg.payload = \"ERROR: El agente LLM no respondió. Revisar API key, cuota o modelo. Se conserva la predicción de la red neuronal como respaldo.\";\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1470,
        "y": 680,
