    {
        "id": "014a8ba98845485e",
        "type": "function",
        "z": "5ca8cb27f5ecfc74",
        "name": "Procesar UI",
        "func": "let d = msg.payload;\nlet radPct = Math.round(d.rad / 4095 * 100);\n\nlet alerta = \"NORMAL\";\n\nif (d.suelo < 30 && d.temp > 30 && radPct > 70) {\n    alerta = \"ALERTA CRÍTICA: riesgo de estrés hídrico\";\n} else if (d.suelo < 30) {\n    alerta = \"ALERTA: humedad del suelo baja\";\n} else if (d.temp > 32) {\n    alerta = \"ALERTA: temperatura elevada\";\n} else if (radPct > 85) {\n    alerta = \"Aviso: radiación solar muy alta\";\n} else if (d.hum < 30) {\n    alerta = \"ALERTA: humedad ambiente baja\";\n}\n\nreturn [\n    { payload: d.temp },\n    { payload: d.hum },\n    { payload: d.suelo },\n    { payload: radPct },\n    { payload: alerta },\n    { payload: d.parcela },\n    { payload: d.viento },\n    { payload: d.cultivo }\n];",
        "outputs": 8,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 510,
        "y": 120,
        "wires": [
            [
                "0e46d3cd68b514cc"
