    {
        "id": "9152d66f69d19552",
        "type": "function",
        "z": "5ca8cb27f5ecfc74",
        "name": "Control básico respaldo (Wokwi)",
        "func": "let d = msg.payload;\nlet radPct = Math.round(d.rad / 4095 * 100);\nlet comando = \"SISTEMA OK\";\n\n// Control básico de respaldo para el ESP32.\n// La decisión avanzada se muestra aparte con NeuralNet + Agente LLM.\nif (d.suelo < 30 || d.temp > 32 || radPct > 85) {\n    comando = \"ALERTA CRÍTICA\";\n}\n\nmsg.topic = \"cursoiot/grupo3/comandos\";\nmsg.payload = comando;\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1450,
        "y": 320,
        "wires": [
            [
                "3a7779d78c316557",
                "b6b653fe158081c6"
            ]
        ]
    },
