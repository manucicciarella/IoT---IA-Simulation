    {
        "id": "2c28d6bcae29d0eb",
        "type": "function",
        "z": "5ca8cb27f5ecfc74",
        "name": "Agregar contexto por parcela",
        "func": "let d = msg.payload;\n\nfunction randomEntre(min, max) {\n    return Math.round((Math.random() * (max - min) + min) * 10) / 10;\n}\n\n// Contexto operativo simulado por parcela.\n// El viento se genera dentro de un rango distinto según la zona.\nlet contextoParcelas = {\n    \"Parcela 1\": {\n        viento_min: 5,\n        viento_max: 18,\n        bateria_dron: 82,\n        nivel_tanque: 70,\n        ultimo_riego_horas: 18,\n        ultima_fumigacion_dias: 12,\n        tipo_cultivo: \"soja\",\n        etapa_cultivo: \"floración\"\n    },\n    \"Parcela 2\": {\n        viento_min: 18,\n        viento_max: 32,\n        bateria_dron: 64,\n        nivel_tanque: 55,\n        ultimo_riego_horas: 4,\n        ultima_fumigacion_dias: 2,\n        tipo_cultivo: \"maíz\",\n        etapa_cultivo: \"crecimiento vegetativo\"\n    },\n    \"Parcela 3\": {\n        viento_min: 32,\n        viento_max: 48,\n        bateria_dron: 37,\n        nivel_tanque: 30,\n        ultimo_riego_horas: 2,\n        ultima_fumigacion_dias: 1,\n        tipo_cultivo: \"soja\",\n        etapa_cultivo: \"floración\"\n    },\n    \"Parcela 4\": {\n        viento_min: 3,\n        viento_max: 15,\n        bateria_dron: 91,\n        nivel_tanque: 85,\n        ultimo_riego_horas: 36,\n        ultima_fumigacion_dias: 18,\n        tipo_cultivo: \"trigo\",\n        etapa_cultivo: \"maduración\"\n    }\n};\n\nlet parcela = d.parcela || \"Parcela 1\";\nlet ctxBase = contextoParcelas[parcela] || contextoParcelas[\"Parcela 1\"];\n\nlet viento = Number(d.viento) || randomEntre(ctxBase.viento_min, ctxBase.viento_max);\n\nmsg.sensores = {\n    parcela: parcela,\n    temp: Number(d.temp),\n    hum: Number(d.hum),\n    suelo: Number(d.suelo),\n    rad: Math.round(Number(d.rad) / 4095 * 100),\n    viento: viento\n};\n\nmsg.contexto = {\n    viento: viento,\n    bateria_dron: ctxBase.bateria_dron,\n    nivel_tanque: ctxBase.nivel_tanque,\n    ultimo_riego_horas: ctxBase.ultimo_riego_horas,\n    ultima_fumigacion_dias: ctxBase.ultima_fumigacion_dias,\n    tipo_cultivo: ctxBase.tipo_cultivo,\n    etapa_cultivo: ctxBase.etapa_cultivo\n};\n\n// Si querés que los nodos de UI también puedan leer viento/contexto desde payload:\nmsg.payload = {\n    parcela: parcela,\n    temp: Number(d.temp),\n    hum: Number(d.hum),\n    suelo: Number(d.suelo),\n    rad: Math.round(Number(d.rad) / 4095 * 100),\n    viento: viento,\n    bateria_dron: ctxBase.bateria_dron,\n    nivel_tanque: ctxBase.nivel_tanque,\n    ultimo_riego_horas: ctxBase.ultimo_riego_horas,\n    ultima_fumigacion_dias: ctxBase.ultima_fumigacion_dias,\n    tipo_cultivo: ctxBase.tipo_cultivo,\n    etapa_cultivo: ctxBase.etapa_cultivo\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 160,
        "y": 560,
        "wires": [
            [
                "aea1ef970d3250b6",
                "31d1ee497fc37735"
            ]
        ]
    },
