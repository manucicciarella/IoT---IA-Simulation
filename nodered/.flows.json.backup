    {
        "id": "ccab8bc38c90af33",
        "type": "neuralnet",
        "z": "0329be821138bde4",
        "name": "Red Neuronal Agro",
        "learningRate": 0.3,
        "errorThresh": 0.005,
        "iterations": 3000,
        "log": true,
