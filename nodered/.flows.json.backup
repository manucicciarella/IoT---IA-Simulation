        "type": "function",
        "z": "0329be821138bde4",
        "name": "Accion para UI",
        "func": "msg.payload = msg.accion;\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
