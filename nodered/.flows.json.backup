                "fn_decode_aa001"
            ]
        ]
    },
    {
        "id": "inj_train_aa001",
        "type": "inject",
        "z": "0329be821138bde4",
        "name": "Iniciar entrenamiento",
        "props": [
            {
                "p": "payload",
                "v": "",
                "vt": "date"
            }
        ],
        "repeat": "",
        "crontab": "",
        "once": true,
        "onceDelay": 3,
        "topic": "",
        "payload": "",
        "payloadType": "date",
        "x": 170,
        "y": 480,
        "wires": [
            [
                "file_in_aa001"
            ]
        ]
    },
    {
        "id": "file_in_aa001",
        "type": "file in",
        "z": "0329be821138bde4",
        "name": "Leer dataset",
        "filename": "/data/dataset_agro_nodered_sin_bateria.json",
        "filenameType": "str",
        "format": "utf8",
        "chunk": false,
        "sendError": false,
        "encoding": "none",
        "allProps": false,
        "x": 390,
        "y": 480,
        "wires": [
            [
                "fn_parse_aa001"
            ]
        ]
    },
    {
        "id": "fn_parse_aa001",
        "type": "function",
        "z": "0329be821138bde4",
        "name": "Parsear dataset",
        "func": "try {\n    msg.trainData = JSON.parse(msg.payload.toString());\n    msg.neuralNetworkOptions = {\n        learningRate: 0.3,\n        errorThresh: 0.005,\n        iterations: 3000,\n        hiddenLayers: [10, 6]\n    };\n    node.status({fill:\"green\",shape:\"dot\",text:msg.trainData.length+\" samples OK\"});\n    return msg;\n} catch(e) {\n    node.error(\"Dataset parse failed: \"+e.message, msg);\n    node.status({fill:\"red\",shape:\"ring\",text:\"parse error: \"+e.message});\n    return null;\n}",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 610,
        "y": 480,
        "wires": [
            [
                "ccab8bc38c90af33"
            ]
        ]
    },
    {
        "id": "fn_norm_aa001",
        "type": "function",
        "z": "0329be821138bde4",
        "name": "Normalizar entrada",
        "func": "let d = msg.payload;\nmsg.runData = {\n    temp: parseFloat((d.temp / 50).toFixed(4)),\n    hum_amb: parseFloat((d.hum / 100).toFixed(4)),\n    hum_suelo: parseFloat((d.suelo / 100).toFixed(4)),\n    radiacion: parseFloat((d.rad / 100).toFixed(4)),\n    viento: parseFloat((d.viento / 120).toFixed(4))\n};\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 570,
        "y": 320,
        "wires": [
            [
                "ccab8bc38c90af33"
            ]
        ]
    },
    {
        "id": "fn_decode_aa001",
        "type": "function",
        "z": "0329be821138bde4",
        "name": "Decodificar salida NN",
        "func": "const ACCIONES = {\"0\":\"Normal\",\"1\":\"Regar\",\"2\":\"Fumigar\",\"3\":\"Alerta critica\",\"4\":\"Inspeccionar\"};\nconst COMANDOS = {\"0\":\"SISTEMA OK\",\"1\":\"Regar\",\"2\":\"Fumigar\",\"3\":\"ALERTA\",\"4\":\"Inspeccionar\"};\nlet salida = msg.decision;\nif (!salida || typeof salida[\"0\"] === \"undefined\") return null;\nlet maxKey = Object.keys(salida).reduce((a, b) => salida[a] > salida[b] ? a : b);\nmsg.accion = ACCIONES[maxKey];\nmsg.topic = \"cursoiot/Agus/comando\";\nmsg.payload = COMANDOS[maxKey];\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1080,
        "y": 320,
        "wires": [
            [
                "9fb72521d62fb3fc",
                "21077e1d488a4997",
                "fn_accion_ui_aa001"
            ]
        ]
    },
    {
        "id": "fn_accion_ui_aa001",
        "type": "function",
        "z": "0329be821138bde4",
        "name": "Accion para UI",
        "func": "msg.payload = msg.accion;\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1080,
        "y": 420,
        "wires": [
            [
                "ui_nn_accion_aa001"
            ]
        ]
    },
