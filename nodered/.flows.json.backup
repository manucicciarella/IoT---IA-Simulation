    {
        "id": "aea1ef970d3250b6",
        "type": "function",
        "z": "5ca8cb27f5ecfc74",
        "name": "Preparar Entrada IA",
        "func": "let d = msg.sensores;\n\n// La red neuronal fue entrenada con valores normalizados entre 0 y 1.\nmsg.runData = {\n    temp: Number(d.temp) / 50,\n    hum_amb: Number(d.hum) / 100,\n    hum_suelo: Number(d.suelo) / 100,\n    radiacion: Number(d.rad) / 100,\n    viento: Number(d.viento) / 120\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 420,
        "y": 580,
        "wires": [
            [
                "f1a323f9774314e8"
            ]
        ]
    },
    {
        "id": "48e1f36b9ebe1599",
        "type": "function",
        "z": "5ca8cb27f5ecfc74",
        "name": "Interpretar Prediccion IA",
        "func": "// Si el mensaje viene del entrenamiento, lo ignoramos\nif (msg.trainData || msg.net || msg.result) {\n    return null;\n}\n\n// La predicción suele venir en msg.decision\nlet pred = msg.decision;\n\nif (!pred) {\n    msg.payload = \"IA: sin predicción\";\n    return msg;\n}\n\nlet clases = {\n    \"0\": \"NORMAL\",\n    \"1\": \"REGAR\",\n    \"2\": \"FUMIGAR\",\n    \"3\": \"ALERTA CRÍTICA\",\n    \"4\": \"INSPECCIONAR\"\n};\n\nlet mejorClase = null;\nlet mejorValor = -1;\n\nfor (let clase in pred) {\n    let valor = Number(pred[clase]);\n\n    if (valor > mejorValor) {\n        mejorValor = valor;\n        mejorClase = clase;\n    }\n}\n\nmsg.payload = \"IA: \" + clases[mejorClase] + \" (\" + (mejorValor * 100).toFixed(1) + \"%)\";\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 850,
        "y": 480,
        "wires": [
            [
                "f0bb56959c0a03b3",
                "483b4c6ec9b6cc9f",
                "0866c3493ef2709a"
            ]
        ]
    },
